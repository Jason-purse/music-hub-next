# MusicHub 环境变量示例
# 复制为 .env.local 使用

# ── 基础配置 ──────────────────────────────────────────
ADMIN_TOKEN=your_admin_token_here

# ── GitHub Storage（生产环境必填，本地开发可不填）──────
# 有 GITHUB_TOKEN → 用 GitHub API 读写插件文件（Vercel 生产）
# 无 GITHUB_TOKEN → 用本地文件系统（本地开发）
GITHUB_TOKEN=ghp_xxxx
GITHUB_CONTENT_REPO=Jason-purse/music-hub-next
GITHUB_CONTENT_BRANCH=main
